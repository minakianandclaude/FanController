menu "VanFan Controller"

    menu "WiFi Configuration"
        config VANFAN_WIFI_SSID
            string "WiFi SSID"
            default "YOUR_WIFI_SSID"
            help
                SSID of your WiFi network.

        config VANFAN_WIFI_PASSWORD
            string "WiFi Password"
            default "YOUR_WIFI_PASSWORD"
            help
                Password of your WiFi network.
    endmenu

    menu "Network"
        config VANFAN_MDNS_HOSTNAME
            string "mDNS Hostname"
            default "vanfan"
            help
                mDNS hostname (accessible as <hostname>.local).
    endmenu

    menu "BTS7960 Pin Assignments"
        config VANFAN_PIN_RPWM
            int "RPWM GPIO (forward PWM)"
            default 5

        config VANFAN_PIN_LPWM
            int "LPWM GPIO (reverse PWM)"
            default 6

        config VANFAN_PIN_R_EN
            int "R_EN GPIO (right enable)"
            default 7

        config VANFAN_PIN_L_EN
            int "L_EN GPIO (left enable)"
            default 15

        config VANFAN_PIN_R_IS
            int "R_IS GPIO (right current sense, ADC)"
            default 4

        config VANFAN_PIN_L_IS
            int "L_IS GPIO (left current sense, ADC)"
            default 3
    endmenu

    menu "Button Pin Assignments"
        config VANFAN_PIN_BTN_SPEED
            int "Speed button GPIO"
            default 9

        config VANFAN_PIN_BTN_DIRECTION
            int "Direction button GPIO"
            default 10
    endmenu

    menu "Status LED"
        config VANFAN_PIN_STATUS_LED
            int "Status LED GPIO (WS2812B)"
            default 46
    endmenu

endmenu
